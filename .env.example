# Use your Neon pooled connection string in production/development with DB persistence.
# Example: postgresql://user:password@ep-name-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional. MongoDB Atlas — supplementary backup or primary Notes store (see NOTES_STORE).
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Optional database name (default: cs_hub)
MONGODB_DB_NAME=cs_hub
# Notes storage: atlas (default when MONGODB_URI set) | neon | backup
NOTES_STORE=atlas

# Optional. When set, Dev Vault secrets are encrypted before they are stored.
SECRET_ENCRYPTION_KEY=
# Optional. When set, deployed API routes require this Bearer token.
APP_ACCESS_TOKEN=
# Required in production for username/password sessions (use a long random string).
JWT_SECRET=
PORT=3001
VITE_API_URL=/api
